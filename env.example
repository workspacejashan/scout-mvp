# Backend
# Use 127.0.0.1 + non-default ports to avoid conflicts with local Postgres/Redis.
DATABASE_URL=postgresql+psycopg2://scout:scout@127.0.0.1:5433/scout
REDIS_URL=redis://127.0.0.1:6380/0

APP_DEFAULT_OWNER_ID=local-owner

# Environment
# - development: permissive local defaults
# - production: auth is required; docs/openapi are disabled; DB tables are not auto-created
ENV=development

# REQUIRED IN PRODUCTION: protects all /api endpoints.
# Set the same value in BOTH backend and frontend runtime environments.
ADMIN_API_TOKEN=

# Google CSE (DEPRECATED - scouting now uses Scrape.do to fetch Google SERP HTML)
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_CX=

# OpenRouter (for copilot suggestions)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# OpenAI (for CSE profile extraction - cheaper than OpenRouter)
OPENAI_API_KEY=

# Enrichment (next step)
# Options:
# - disabled
# - enformiongo
# - scrapedo_advancedbackgroundchecks
ENRICH_PROVIDER=disabled
ENFORMIONGO_API_KEY=
SCRAPEDO_API_KEY=

# Scrape.do SERP anti-block options
# super=true uses better residential/mobile proxies
SCRAPEDO_SERP_SUPER=true
# Always use headless browser for SERP (more reliable, slower)
SCRAPEDO_SERP_RENDER_ALWAYS=true
# If we detect a consent/block page, retry that page with a headless browser
SCRAPEDO_SERP_RENDER_ON_BLOCK=true
# Wait a bit for the headless browser to fully load
SCRAPEDO_SERP_CUSTOM_WAIT_MS=2000
# Wait until SERP results container is present (only used when render=true)
SCRAPEDO_SERP_WAIT_SELECTOR=div#search
# Scrape.do flag; docs suggest setting this to false when troubleshooting consent pages
SCRAPEDO_SERP_BLOCK_RESOURCES=false

# Scout settings (Google SERP via Scrape.do)
# Notes:
# - Google SERP is effectively 10 results/page (CSE_RESULTS_PER_PAGE is ignored for now).
# - CSE_MAX_RESULTS controls how deep we try to paginate (e.g. 200 = 20 pages).
CSE_RESULTS_PER_PAGE=10
CSE_MAX_RESULTS=200
# Keep low to reduce captcha risk; 1-2 recommended.
CSE_PAGE_CONCURRENCY=1
CSE_PAGE_RETRIES=2

# LLM fallback for messy CSE parsing (name/location). Uses OpenRouter when configured.
CSE_LLM_EXTRACT_ENABLED=true
CSE_LLM_EXTRACT_BATCH_SIZE=8

# Frontend
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000

# Server-side backend base URL used by Next.js proxy (NOT exposed to browser).
# In production you can set this to your internal backend URL.
BACKEND_URL=http://127.0.0.1:8000

# Redis URL for frontend OTP store (shares the same Redis as the backend).
# If not set, OTPs are stored in-memory (single-instance only).
REDIS_URL=redis://127.0.0.1:6380/0

# Frontend strict access control (required if you want the app private).
# AUTH_SECRET: strong random string used to sign the session cookie.
AUTH_SECRET=

# Email OTP authentication.
# Comma-separated list of email addresses allowed to sign in.
ADMIN_EMAILS=

# Resend API key for sending OTP emails (https://resend.com).
RESEND_API_KEY=

# SMS Outreach (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Default FROM number (E.164). Can be overridden in DB owner settings.
TWILIO_FROM_NUMBER=

# Outreach defaults
SMS_COOLDOWN_DAYS=14
SMS_GLOBAL_DAILY_LIMIT=200
SMS_JOB_DAILY_LIMIT=50
SMS_SENDING_ENABLED=false